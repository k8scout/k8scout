      "rule_id": "PRIVESC-CLUSTER-ADMIN-BINDING",
      "severity": "CRITICAL",
      "score": 10.0,
      "title": "ServiceAccount can escalate to cluster-admin via impersonation",
      "description": "The ci-runner ServiceAccount holds the ci-deployer ClusterRole which grants impersonate rights on serviceaccounts. Combined with patch access to workloads, this allows privilege escalation to cluster-admin by injecting a new pod spec.",
      "evidence": [
        "ClusterRoleBinding ci-runner-binding → ClusterRole ci-deployer",
        "ClusterRole ci-deployer: verbs=[impersonate] resources=[serviceaccounts]",
        "ClusterRole ci-deployer: verbs=[patch] resources=[deployments,daemonsets]"
      ],
      "mitigation": "Remove impersonate verb from ci-deployer. Restrict patch access to specific deployment names using resourceNames.",
      "affected_nodes": [
