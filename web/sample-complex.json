  "risk_findings": [
    {
      "id": "f-001",
      "rule_id": "PRIVESC-RBAC-WRITE-CLUSTER-ADMIN",
      "severity": "CRITICAL",
      "score": 10.0,
      "title": "CI SA can create ClusterRoleBinding to grant cluster-admin to any subject",
      "description": "The github-actions ServiceAccount holds ci-deploy-master which grants create/patch on clusterrolebindings cluster-wide. An attacker can create a new ClusterRoleBinding granting cluster-admin to github-actions itself, achieving full cluster takeover in a single API call.",
      "evidence": [
        "ClusterRoleBinding github-actions-deploy → ClusterRole ci-deploy-master",
        "ClusterRole ci-deploy-master: verbs=[get,list,watch,create,patch,delete] resources=[clusterrolebindings] apiGroups=[rbac.authorization.k8s.io]",
        "ClusterRole cluster-admin exists: verbs=[*] resources=[*]"
      ],
      "mitigation": "Remove all RBAC write verbs from ci-deploy-master. Use a dedicated RBAC controller with audit logging. Never grant clusterrolebinding write to CI identities.",
      "affected_nodes": [
        "sa:ci:github-actions",
        "crb:github-actions-deploy",
        "cr:ci-deploy-master",
        "cr:cluster-admin"
      ]
    },
    {
      "id": "f-002",
      "rule_id": "PRIVESC-IMPERSONATE-PAYMENTS-SA",
      "severity": "CRITICAL",
      "score": 9.8,
      "title": "CI SA can impersonate payments-processor to access PCI secrets",
      "description": "ci-deploy-master grants impersonate on serviceaccounts cluster-wide. By impersonating payments-processor, an attacker gains access to stripe-api-key and pci-tls-cert secrets in the payments namespace, directly violating PCI DSS controls.",
      "evidence": [
        "ClusterRole ci-deploy-master: verbs=[impersonate] resources=[serviceaccounts]",
        "ServiceAccount payments:payments-processor bound to payments-admin ClusterRole",
        "payments-admin grants get on secrets: payments/stripe-api-key, payments/pci-tls-cert"
      ],
      "mitigation": "Remove impersonate verb from ci-deploy-master entirely. If service-account impersonation is required, scope it to specific SA names using resourceNames field.",
      "affected_nodes": [
        "sa:ci:github-actions",
        "cr:ci-deploy-master",
        "sa:payments:payments-processor",
        "crb:payments-svc-admin",
        "cr:payments-admin",
        "secret:payments:stripe-api-key",
        "secret:payments:pci-tls-cert"
      ]
    },
    {
      "id": "f-003",
      "rule_id": "SECRET-EXFIL-ADMIN-KUBECONFIG",
      "severity": "CRITICAL",
      "score": 9.5,
      "title": "CI SA can read kube-system admin kubeconfig secret",
      "description": "ci-deploy-master includes get on secrets cluster-wide without namespace scoping. The admin-kubeconfig secret in kube-system contains full cluster-admin credentials, granting permanent out-of-band cluster access beyond Kubernetes RBAC.",
      "evidence": [
        "ClusterRole ci-deploy-master: verbs=[get,list] resources=[secrets] — no namespace restriction",
        "Secret kube-system/admin-kubeconfig exists (risk_score 10.0)"
      ],
      "mitigation": "Delete admin-kubeconfig from kube-system. Restrict secret get to specific namespaces using RoleBindings instead of ClusterRoleBindings.",
      "affected_nodes": [
        "sa:ci:github-actions",
        "cr:ci-deploy-master",
        "secret:kube-system:admin-kubeconfig"
      ]
    },
    {
      "id": "f-004",
      "rule_id": "SECRET-EXFIL-JWT-SIGNING-KEY",
      "severity": "CRITICAL",
      "score": 9.2,
      "title": "Multiple SAs can read JWT signing key — full auth bypass",
      "description": "The production/jwt-signing-key secret is accessible to three separate SAs (ci:github-actions via ci-deploy-master, monitoring:prometheus via monitoring-viewer, and istio-system:istio-pilot via istio-sidecar-inject role). Possession of this key allows forging valid JWTs for any user.",
      "evidence": [
        "ClusterRole ci-deploy-master: can_get secret:production:jwt-signing-key",
        "ClusterRole monitoring-viewer: can_get secret:production:jwt-signing-key",
        "Role production/istio-sidecar-inject: can_get secret:production:jwt-signing-key"
      ],
      "mitigation": "Store JWT signing keys in Vault or an external KMS, not as Kubernetes secrets. Rotate the key immediately if any of these SAs is compromised.",
      "affected_nodes": [
